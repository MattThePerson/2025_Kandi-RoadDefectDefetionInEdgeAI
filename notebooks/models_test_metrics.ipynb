{
 "cells": [
  {
   "cell_type": "markdown",
   "id": "318e34a0",
   "metadata": {},
   "source": "# Computing and Saving Test Metrics for Trained Models"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "006be952",
   "metadata": {},
   "outputs": [],
   "source": [
    "# NOTE: run only once!\n",
    "import os\n",
    "os.chdir('..')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c41c3d1f",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "import time\n",
    "import pickle\n",
    "import shutil\n",
    "import polars as pl\n",
    "\n",
    "from ultralytics import YOLO # type: ignore\n",
    "from ultralytics import settings\n",
    "from ultralytics.utils import metrics\n"
   ]
  },
  {
   "cell_type": "code",
   "id": "6d8debaa",
   "metadata": {},
   "source": [
    "PURPLE = \"\\033[0;35m\"\n",
    "END = \"\\033[0m\""
   ]
  },
  {
   "cell_type": "code",
   "id": "084910a2",
   "metadata": {},
   "source": [
    "# YOLO setup\n",
    "\n",
    "# Set datasets (root) directory path\n",
    "DATASETS_DIR = \"datasets\"\n",
    "RUNS_DIR = \"./ultralytics/runs\"\n",
    "WEIGHTS_DIR = \"./ultralytics/weights\"\n",
    "\n",
    "if not Path(DATASETS_DIR).exists():\n",
    "    raise FileNotFoundError(f\"Please set path to existing folder. Current doesn't exist: '{DATASETS_DIR}'\")\n",
    "\n",
    "# Set yaml file\n",
    "YAML_FILE = \"./YAML/RDD2022_kaikki.yaml\"\n",
    "if not Path(YAML_FILE).exists():\n",
    "    raise FileNotFoundError(f\"Please set path to existing YAML file. Current doesn't exist: '{YAML_FILE}'\")\n",
    "\n",
    "# YOLO settings\n",
    "settings.reset() # resets YOLO settings\n",
    "settings.update({\n",
    "    \"datasets_dir\": str(DATASETS_DIR),\n",
    "    \"runs_dir\":     str(RUNS_DIR),\n",
    "    \"weights_dir\":  str(WEIGHTS_DIR),\n",
    "})\n",
    "# settings"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "id": "bd92e9fe",
   "metadata": {},
   "source": [
    "# Get model paths\n",
    "filters = [\n",
    "    # 'long_runs',\n",
    "    # '150ep',\n",
    "    # 'normal',\n",
    "    # \"bch_32\",\n",
    "]\n",
    "\n",
    "# choose which model formats to test\n",
    "model_names = ['best.pt', 'best_full_integer_quant.tflite']\n",
    "base_dir = 'runs_puhti'  # base folder for model directories\n",
    "\n",
    "\n",
    "run_paths = []\n",
    "for name in model_names:\n",
    "    run_paths.extend(Path(base_dir).rglob(name))\n",
    "\n",
    "run_paths = sorted(\n",
    "    run_paths,\n",
    "    key=lambda obj: str(obj),\n",
    ")\n",
    "\n",
    "run_paths = [ p.parent.parent for p in run_paths ]\n",
    "for f in filters:\n",
    "    run_paths = [ p for p in run_paths if f in str(p) ]\n",
    "print(\"number of runs selected:\", len(run_paths))"
   ]
    "    run_paths = [ p for p in run_paths if f in str(p) ]\n",
    "    "
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "markdown",
   "id": "f3d92779",
   "metadata": {},
   "source": "### STEP 1: compute metrics"
  },
  {
   "cell_type": "code",
   "id": "98508888",
   "metadata": {},
   "source": [
    "test_image_sizes = [640, 320]\n",
    "\n",
    "run_count = ( len([p for p in run_paths if p.name.find(\".\") == -1 ])*len(test_image_sizes)  # runs count for non-quantized models\n",
    "             + len([p for p in run_paths if p.name.find(\".\") > -1 ]))  # run count for quantized models\n",
    "\n",
    "print(f\"Running up to {run_count} model tests, this may take a while...\")\n",
    "\n",
    "# RUN: Compute metrics for test set\n",
    "TEST_METRICS_FOLDER_base = \"test_split_metrics\"\n",
    "# save metrics file name format \"TEST_METRICS_FOLDER_base.quant/original.640/320\"\n",
    "\n",
    "REDO = True\n",
    "for imgsz in test_image_sizes:\n",
    "    for i, run_path in enumerate(run_paths):\n",
    "        print(f\"Testing model: {run_path} | Test image size: {imgsz}\")\n",
    "        \n",
    "        # check for image size mismatch, quantized models can only run inference at their export imgsz\n",
    "        if run_path.name.count(\".\") > 0 and not run_path.name.endswith(f\".{imgsz}\"):\n",
    "            # print(f\"\\nSkipping model.val() for {run_path.name} with imgsz={imgsz} due to image size mismatch.\\n\")\n",
    "            continue\n",
    "        \n",
    "        if Path(run_path / \"weights/best.pt\").exists():\n",
    "            model_path = run_path / \"weights/best.pt\"\n",
    "            \n",
    "            # modify results foder name\n",
    "            TEST_METRICS_FOLDER = \".\".join([TEST_METRICS_FOLDER_base, \"original\", str(imgsz)])\n",
    "            \n",
    "        elif Path(run_path / \"best_saved_model/best_full_integer_quant.tflite\").exists():\n",
    "            model_path = run_path / \"best_saved_model/best_full_integer_quant.tflite\"\n",
    "            \n",
    "            # modify results foder name\n",
    "            TEST_METRICS_FOLDER = \".\".join([TEST_METRICS_FOLDER_base, \"quant\", str(imgsz)])\n",
    "        else:\n",
    "            raise FileNotFoundError(f\"No model found in {run_path}\")\n",
    "        \n",
    "        name = str(run_path).replace(\"\\\\\", \"/\")\n",
    "        print(f\"  [{i+1:>2}/{run_count}] VALIDATING: \\\"{PURPLE}{name}{END}\\\"\")\n",
    "        \n",
    "        # paths and check\n",
    "        results_dir = run_path / TEST_METRICS_FOLDER\n",
    "        results_pkl = results_dir / \"metrics.pkl\"\n",
    "        if results_pkl.exists() and not REDO:\n",
    "            print('  ... skipping')\n",
    "            continue\n",
    "        \n",
    "        # validate\n",
    "        start = time.time()\n",
    "        model = YOLO(model_path)\n",
    "        \n",
    "        results: metrics.DetMetrics = model.val(\n",
    "            data = YAML_FILE,\n",
    "            split = \"test\",\n",
    "            task = \"detect\",\n",
    "            project = run_path,\n",
    "            name = TEST_METRICS_FOLDER,\n",
    "            imgsz = imgsz\n",
    "        )\n",
    "            \n",
    "        print(\"  ... took {:.1f} sec\".format(time.time()-start))\n",
    "    \n",
    "        # save pickle\n",
    "        results_pkl.parent.mkdir(exist_ok=True)\n",
    "        print(f\"pickling results to: '{results_pkl}'\")\n",
    "        with open(results_pkl, \"wb\") as f:\n",
    "            pickle.dump(results, f)\n",
    "        \n",
    "        # move saved images to desired dir\n",
    "        matches = list(Path(RUNS_DIR).rglob(f\"*{run_path}/{TEST_METRICS_FOLDER}\"))\n",
    "        if len(matches) == 0:\n",
    "            raise FileExistsError(f\"cant find images generated by .val().\")\n",
    "        images_path = matches[0]\n",
    "        new_images_path = Path(\"./\") / images_path.relative_to(f\"{RUNS_DIR}/detect\") / \"images\"\n",
    "        print('moving images dir to:', new_images_path)\n",
    "        if not new_images_path.exists():\n",
    "            shutil.move(images_path, new_images_path)"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "markdown",
   "id": "e46f7b96",
   "metadata": {},
   "source": [
    "### STEP 2: Metrics processing"
   ]
  },
  {
   "cell_type": "code",
   "id": "67e851f3",
   "metadata": {},
   "source": [
    "# TEST: get metrics.pkl from path\n",
    "run_path = run_paths[0]\n",
    "# metrics_pkl_path = run_path / TEST_METRICS_FOLDER / \"metrics.pkl\"\n",
    "metrics_pkl_path = next(run_path.glob(\"**/metrics.pkl\"), None)\n",
    "print(\"pkl path: \", metrics_pkl_path)\n",
    "\n",
    "if metrics_pkl_path is None:\n",
    "    print(\"metrics.pkl not found\")    \n",
    "\n",
    "metrics_pkl_path.exists()\n",
    "results: metrics.DetMetrics\n",
    "with open(metrics_pkl_path, 'rb') as f:\n",
    "    results = pickle.load(f)\n",
    "results"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "id": "317434de",
   "metadata": {},
   "source": [
    "# Read pickled metrics, build dataframe of metrics and save to csv\n",
    "col_names = \"Class mAP50 mAP50-95 Box-P Box-R Box-F1\".split()\n",
    "class_names = \"mean D00 D10 D20 D40\".split()\n",
    "\n",
    "# construct data dict\n",
    "new_col_names = [\n",
    "    f\"{col}_{cls}\"\n",
    "    for col in col_names if col != \"Class\"\n",
    "    for cls in class_names\n",
    "]\n",
    "data: dict[str, list[pl.Float64]] = { k: [] for k in new_col_names }\n",
    "\n",
    "metrics_pkl_paths = []\n",
    "for run_path in run_paths:\n",
    "    # metrics_pkl_path = run_path / TEST_METRICS_FOLDER / \"metrics.pkl\"\n",
    "    for p in list(run_path.glob(\"**/metrics.pkl\")):\n",
    "        metrics_pkl_paths.append(p)\n",
    "\n",
    "# print(\"pkl paths: \", metrics_pkl_paths)\n",
    "\n",
    "# iterate\n",
    "for metrics_pkl_path in metrics_pkl_paths:\n",
    "        \n",
    "    metrics_pkl_path.exists()\n",
    "    results: metrics.DetMetrics\n",
    "    with open(metrics_pkl_path, 'rb') as f:\n",
    "        results = pickle.load(f)\n",
    "\n",
    "    # get results df\n",
    "    df = results.to_df()\n",
    "    df = df[col_names]\n",
    "\n",
    "    # compute mean row\n",
    "    mean_row = (\n",
    "        df\n",
    "        .select(pl.exclude(\"Class\").mean())\n",
    "        .with_columns(pl.lit(\"mean\").alias(\"Class\"))\n",
    "        .select(df.columns)   # reorder\n",
    "    )\n",
    "    df = pl.concat([df, mean_row], how=\"vertical\")\n",
    "\n",
    "    # add values to data{}\n",
    "    for cls in class_names:\n",
    "        cls_d = df.filter(pl.col(\"Class\") == cls).to_dict(as_series=False)\n",
    "        del cls_d[\"Class\"]\n",
    "        for k, v in cls_d.items():\n",
    "            key = f\"{k}_{cls}\"\n",
    "            data[key] = data.get(key, []) + v\n",
    "\n",
    "# create new df and save csv\n",
    "pkl_paths_short =  [str(p).replace(base_dir, \"\").split('/') for p in metrics_pkl_paths]\n",
    "run_groups = [p[1] for p in pkl_paths_short]\n",
    "run_names =  [p[2].split(\".\")[0] for p in pkl_paths_short]\n",
    "run_quant = [p[3].split(\".\")[1] for p in pkl_paths_short]\n",
    "run_imgsz = [int(p[3].split(\".\")[2]) for p in pkl_paths_short]\n",
    "d = { \"model_name\": run_names, \"run_group\": run_groups, \"quantized\": run_quant, \"imgsz\": run_imgsz } | data # add run_name as col\n",
    "df_all = pl.DataFrame(d)\n",
    "df_all.write_csv(\"analytics/metrics_table.csv\")\n",
    "df_all"
   ],
   "outputs": [],
   "execution_count": null
  },
